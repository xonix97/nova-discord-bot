# Copy this file to ".env" and fill in your values.
# Get these from https://discord.com/developers/applications

DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-id-here

# Optional: a single guild (server) ID for instant slash-command updates while developing.
# Leave blank to deploy commands globally (can take up to 1 hour to appear).
GUILD_ID=

# Channel ID where new-member welcome messages are sent. Leave blank to disable.
WELCOME_CHANNEL_ID=

# Channel ID where moderation actions are logged. Leave blank to disable.
MOD_LOG_CHANNEL_ID=
